1. modules/file_manager.py — ensure_voice_sample_compatibility
What changed: Removed the early-return for already-compatible files. Always writes a _ttsready.wav copy to the output directory.
Old behavior:
def ensure_voice_sample_compatibility(input_path, output_dir=None):
    input_path = str(input_path)
    ext = os.path.splitext(input_path)[1].lower()
    basename = os.path.splitext(os.path.basename(input_path))[0]
    output_dir = output_dir or os.path.dirname(input_path)
    output_path = os.path.join(output_dir, basename + "_ttsready.wav")
    try:
        info = sf.info(input_path)
        if (ext == '.wav' and info.samplerate == 24000 and info.channels == 1):
            return input_path  # <-- returned early, no copy made
    except Exception:
        pass
    cmd = ["ffmpeg", "-y", "-i", input_path, "-ar", "24000", "-ac", "1", output_path]
    subprocess.run(cmd, ...)
    return output_path
New behavior:
def ensure_voice_sample_compatibility(input_path, output_dir=None):
    input_path = Path(input_path)
    output_dir = Path(output_dir) if output_dir else input_path.parent
    basename = input_path.stem
    output_name = basename if basename.endswith("_ttsready") else f"{basename}_ttsready"
    output_path = output_dir / f"{output_name}.wav"
    if input_path.resolve() == output_path.resolve():
        return str(output_path)  # only skips if src == dest
    output_dir.mkdir(parents=True, exist_ok=True)
    cmd = ["ffmpeg", "-y", "-i", str(input_path), "-ar", "24000", "-ac", "1", str(output_path)]
    subprocess.run(cmd, ...)
    return str(output_path)
